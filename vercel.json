{
  "version": 2,
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/api/index.js" }
  ]
}
